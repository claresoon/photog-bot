# Copy this to apps/bot/.env and apps/dashboard/.env and fill in real values.
# See README.md for where each value comes from.

# --- Supabase (shared by both apps) ---
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=xxxxxxxxxxxx

# --- Bot (apps/bot) ---
TELEGRAM_BOT_TOKEN=xxxxxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_BOT_USERNAME=YourBot
# Set only if running the bot via webhook instead of long polling.
BOT_WEBHOOK_URL=
BOT_WEBHOOK_SECRET=

# --- Dashboard (apps/dashboard) ---
# Same bot token as above — used to verify the Telegram Login Widget payload.
TELEGRAM_BOT_TOKEN=xxxxxxxxxxxx:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=YourBot
# Random 32+ char secret used to sign the iron-session cookie.
SESSION_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_APP_URL=http://localhost:3000
