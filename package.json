{
  "name": "photog-bot",
  "private": true,
  "version": "0.1.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:bot": "pnpm --filter @photog-bot/bot dev",
    "dev:dashboard": "pnpm --filter @photog-bot/dashboard dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:migrate": "supabase db push",
    "db:types": "supabase gen types typescript --local > packages/shared/src/types/database.ts"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
